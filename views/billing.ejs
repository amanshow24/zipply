<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include("./partials/head") %>
  <title>Billing & Plans - Zipply</title>
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link rel="stylesheet" href="/css/billing.css" />
</head>
<body>
  <%- include("./partials/nav") %>

  <main
    class="container billing-shell"
    data-billing-shell
    data-user-name="<%= user && user.name ? user.name : '' %>"
    data-user-email="<%= user && user.email ? user.email : '' %>"
  >
    <% const hasActivePaidPlan = currentPlan !== 'NORMAL' && subscription && subscription.expiresAt; %>
    <% const expiresOnIST = hasActivePaidPlan
      ? new Date(subscription.expiresAt).toLocaleString('en-IN', {
          timeZone: 'Asia/Kolkata',
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        })
      : ''; %>

    <div class="page-back-nav">
      <a href="/" class="page-back-link"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    </div>

    <section class="billing-hero">
      <p class="billing-eyebrow">Billing & plans</p>
      <h1 class="billing-title">Upgrade your plan with Razorpay test checkout.</h1>
      <p class="billing-subtitle">Same daily workflow, bigger limits.</p>
      <p class="billing-ist-clock" data-ist-clock>IST: --</p>
      <p class="billing-status-message" id="billingStatus" aria-live="polite"></p>
    </section>

    <section class="billing-summary" aria-label="Current subscription summary">
      <div class="billing-summary__card">
        <span class="billing-summary__value"><%= planLabel %></span>
        <span class="billing-summary__label">Current plan</span>
      </div>
      <div class="billing-summary__card">
        <span class="billing-summary__value"><%= planLimits.shortUrls %></span>
        <span class="billing-summary__label">Daily short URL limit</span>
      </div>
      <div class="billing-summary__card">
        <span class="billing-summary__value"><%= planLimits.qrCodes %></span>
        <span class="billing-summary__label">Daily QR limit</span>
      </div>
      <div class="billing-summary__card">
        <span class="billing-summary__value"><%= usage.shortUrlCount %> links / <%= usage.qrCount %> QR</span>
        <span class="billing-summary__label">Today’s usage</span>
      </div>
    </section>

    <% if (hasActivePaidPlan) { %>
      <p class="billing-expiry-note">Your <strong><%= planLabel %></strong> plan expires on <strong><%= expiresOnIST %> (IST)</strong>.</p>
    <% } %>

    <section class="billing-grid">
      <article class="billing-card">
        <span class="billing-card__badge">Free</span>
        <h2 class="billing-card__title">Normal</h2>
        <p class="billing-card__price">Rs 0 <span>/ month</span></p>
        <ul class="billing-card__list">
          <li><i class="bi bi-check2-circle"></i> 3 short URLs per day</li>
          <li><i class="bi bi-check2-circle"></i> 2 QR codes per day</li>
          <li><i class="bi bi-check2-circle"></i> IST-based daily reset</li>
        </ul>
        <button type="button" class="billing-card__button billing-card__button--light" disabled>Current default</button>
      </article>

      <article class="billing-card <%= currentPlan === 'PRO' ? 'billing-card--featured' : '' %>">
        <% if (currentPlan === 'PRO') { %><span class="billing-card__badge">Active</span><% } %>
        <h2 class="billing-card__title">Pro</h2>
        <p class="billing-card__price">Rs 199 <span>/ month</span></p>
        <ul class="billing-card__list">
          <li><i class="bi bi-check2-circle"></i> 10 short URLs per day</li>
          <li><i class="bi bi-check2-circle"></i> 10 QR codes per day</li>
          <li><i class="bi bi-check2-circle"></i> Monthly test checkout flow</li>
        </ul>
        <button
          type="button"
          class="billing-card__button <%= currentPlan === 'PRO' ? 'billing-card__button--light' : '' %>"
          data-plan-button
          data-plan="PRO"
          <%= (currentPlan === 'PRO' || hasActivePaidPlan) ? 'disabled' : '' %>
        >
          <%= currentPlan === 'PRO' ? 'Current plan' : (hasActivePaidPlan ? 'Locked till expiry' : 'Choose Pro') %>
        </button>
      </article>

      <article class="billing-card billing-card--featured <%= currentPlan === 'PLUS' ? 'billing-card--featured' : '' %>">
        <% if (currentPlan === 'PLUS') { %><span class="billing-card__badge">Active</span><% } else { %><span class="billing-card__badge">Recommended</span><% } %>
        <h2 class="billing-card__title">Plus</h2>
        <p class="billing-card__price">Rs 299 <span>/ month</span></p>
        <ul class="billing-card__list">
          <li><i class="bi bi-check2-circle"></i> 25 short URLs per day</li>
          <li><i class="bi bi-check2-circle"></i> 25 QR codes per day</li>
          <li><i class="bi bi-check2-circle"></i> Signature verification on backend</li>
        </ul>
        <button
          type="button"
          class="billing-card__button"
          data-plan-button
          data-plan="PLUS"
          <%= (currentPlan === 'PLUS' || hasActivePaidPlan) ? 'disabled' : '' %>
        >
          <%= currentPlan === 'PLUS' ? 'Current plan' : (hasActivePaidPlan ? 'Locked till expiry' : 'Choose Plus') %>
        </button>
      </article>
    </section>

    <section class="billing-history">
      <h2 class="billing-history__title">Recent transactions</h2>
      <% if (transactions && transactions.length > 0) { %>
        <div class="table-responsive">
          <table class="billing-history__table">
            <thead>
              <tr>
                <th>Plan</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Order</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach((payment) => { %>
                <tr>
                  <td data-label="Plan"><%= payment.plan %></td>
                  <td data-label="Amount">Rs <%= payment.amount / 100 %></td>
                  <td data-label="Status">
                    <span class="billing-status billing-status--<%= String(payment.status || '').toLowerCase() %>"><%= payment.status %></span>
                  </td>
                  <td data-label="Order"><%= payment.razorpayOrderId %></td>
                  <td data-label="Date"><%= new Date(payment.createdAt).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', dateStyle: 'medium', timeStyle: 'short' }) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="billing-note">No transactions yet. Once you place a test payment, the verified order will appear here.</p>
      <% } %>
      <p class="billing-note">All plan validity and daily counters are calculated in IST. Payments are charged in INR and verified on the server before the plan is upgraded.</p>
    </section>
  </main>

  <%- include("./partials/footer") %>
  <%- include("./partials/scripts") %>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="/js/billing.js" defer></script>
</body>
</html>