<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head") %>
  <title>404 - Zipply</title>
  <link rel="stylesheet" href="/css/404.css" />
</head>
<body>
  <%- include("./partials/nav") %>

  <main class="error404 container">
    <% const pageNotFoundType = typeof notFoundType === "string" ? notFoundType : "short-url"; %>
    <% const isQRNotFound = pageNotFoundType === "qr"; %>

    <div class="page-back-nav">
      <a href="/" class="page-back-link"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    </div>

    <section class="error404__hero">
      <p class="error404__eyebrow">Page not found</p>
      <h1 class="error404__title"><%= isQRNotFound ? "This QR link is unavailable right now." : "This short link is unavailable right now." %></h1>
      <p class="error404__subtitle">
        <% if (typeof message !== "undefined" && message) { %>
          <%= message %>
        <% } else { %>
          <%= isQRNotFound
            ? "The QR may be deleted, expired, or typed incorrectly. Try generating a fresh QR from your workspace."
            : "The URL may be expired, deleted, or typed incorrectly. Try creating a fresh short URL from your dashboard." %>
        <% } %>
      </p>
      <p class="error404__ist-clock" data-ist-clock>IST: --</p>
    </section>

    <section class="error404__panel page-panel" aria-labelledby="error404-actions-title">
      <div class="error404__code-chip">
        <% if (isQRNotFound) { %>
          <i class="bi bi-qr-code"></i>
          <span>QR Not Found</span>
        <% } else { %>
          <i class="bi bi-link-45deg"></i>
          <span>Short URL Not Found</span>
        <% } %>
      </div>

      <h2 id="error404-actions-title" class="error404__heading">Choose your next step</h2>
      <p class="error404__text"><%= isQRNotFound ? "Head back to your QR workspace or return to your dashboard in one click." : "Head back to your workspace or create a new short URL in one click." %></p>

      <div class="error404__actions">
        <% if (isQRNotFound) { %>
          <a class="btn btn-primary" href="/qr">
            <i class="bi bi-qr-code"></i>
            Back to QR Workspace
          </a>
        <% } else { %>
          <a class="btn btn-primary" href="/short-url">
            <i class="bi bi-link-45deg"></i>
            Create Short URL
          </a>
        <% } %>
        <a class="btn btn-outline-info" href="/">
          <i class="bi bi-house"></i>
          Go to Dashboard
        </a>
      </div>
    </section>
  </main>

  <%- include("./partials/footer") %>
  <%- include("./partials/scripts") %>
</body>
</html>
